      "source": [
        "# ─── 1. CONFIGURATION ──────────────────────────────────────────────────\n",
        "DATASET_ROOT = \"/content/Machine_S\"\n",
        "DATASET_NAME = \"Machine_S\"\n",
        "BACKBONE = \"resnet18\"\n",
        "SAVE_DIR = Path(\"results/final_pipeline\")\n",
        "SAVE_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "def overlay_heatmap(image_np, anomaly_map, alpha=0.5):\n",
        "    heat_norm  = (anomaly_map - anomaly_map.min()) / (anomaly_map.max() - anomaly_map.min() + 1e-8)\n",
        "    heat_color = (cm.jet(heat_norm)[:, :, :3] * 255).astype(np.uint8)\n",
        "    image_rgb  = cv2.cvtColor(image_np, cv2.COLOR_GRAY2RGB) if image_np.ndim == 2 else image_np\n",
        "    return cv2.addWeighted(image_rgb, 1 - alpha, heat_color, alpha, 0)"
      ]
    },
