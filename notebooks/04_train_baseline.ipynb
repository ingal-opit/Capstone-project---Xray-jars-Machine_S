        "\n",
        "# ==========================================\n",
        "# SET THRESHOLD & GENERATE METRICS\n",
        "# ==========================================\n",
        "# Set your threshold here!\n",
        "# Either use the suggestion, or type a specific number: CHOSEN_THRESHOLD = 0.6500\n",
        "CHOSEN_THRESHOLD = suggested_threshold\n",
        "\n",
        "print(f\"Using Threshold: {CHOSEN_THRESHOLD:.4f}\\n\")\n",
        "\n",
        "# Convert raw scores to binary Good(0) / Bad(1) predictions\n",
        "y_pred = (y_scores >= CHOSEN_THRESHOLD).astype(int)\n",
        "\n",
        "# Generate the Confusion Matrix\n",
        "tn, fp, fn, tp = confusion_matrix(y_true, y_pred).ravel()\n",
        "\n",
        "print(\"==== CONFUSION MATRIX ====\")\n",
        "print(f\"True Negatives  (Actual Good, Predicted Good): {tn}\")\n",
        "print(f\"False Positives (Actual Good, Predicted Bad):  {fp}\")\n",
        "print(f\"False Negatives (Actual Bad,  Predicted Good): {fn}\")\n",
        "print(f\"True Positives  (Actual Bad,  Predicted Bad):  {tp}\")\n",
        "print(\"==========================\\n\")\n",
        "\n",
        "total_bad = fn + tp\n",
        "escape_rate = (fn / total_bad) * 100 if total_bad > 0 else 0\n",
        "print(f\"Defect Escape Rate: {escape_rate:.2f}% (Percentage of bad jars that slipped through)\\n\")\n",
        "\n",
        "# Plot Confusion Matrix\n",
        "conf_matrix = np.array([[tn, fp], [fn, tp]])\n",
        "plt.figure(figsize=(6, 5))\n",
        "sns.heatmap(conf_matrix, annot=True, fmt='d', cmap='Blues',\n",
        "            xticklabels=['Predicted Good', 'Predicted Bad'],\n",
        "            yticklabels=['Actual Good', 'Actual Bad'])\n",
        "plt.xlabel('Predicted Label')\n",
        "plt.ylabel('True Label')\n",
        "plt.title(f'Confusion Matrix (Threshold: {CHOSEN_THRESHOLD:.4f})')\n",
        "plt.show()\n",
        "\n",
        "# ==========================================\n",
        "# 3. VISUALIZE, SAVE ALL HEATMAPS & ZIP FOLDERS\n",
        "# ==========================================\n",
        "def save_and_zip_all_heatmaps(model, datamodule, threshold, base_dir=SAVE_DIR):\n",
        "    defective_dir = base_dir / \"defective_heatmaps\"\n",
        "    fp_dir = base_dir / \"false_positives\"\n",
        "\n",
        "    # Clear out the folders if they already exist so we don't mix old runs\n",
        "    if defective_dir.exists(): shutil.rmtree(defective_dir)\n",
        "    if fp_dir.exists(): shutil.rmtree(fp_dir)\n",
        "\n",
        "    defective_dir.mkdir(parents=True, exist_ok=True)\n",
        "    fp_dir.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "    device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "    model.eval()\n",
        "    model.to(device)\n",
        "\n",
        "    datamodule.setup(stage=\"test\")\n",
        "    test_loader = datamodule.test_dataloader()\n",
        "\n",
        "    saved_defective = 0\n",
        "    saved_fp = 0\n",
        "\n",
        "    print(\"Generating and Saving ALL Visual Reports...\")\n",
        "    print(\"(Inline display disabled so your notebook doesn't crash from too many images)\")\n",
        "\n",
        "    for batch in test_loader:\n",
        "        images = batch.image.to(device)\n",
        "        gt_labels = batch.gt_label\n",
        "        image_paths = batch.image_path\n",
        "\n",
        "        with torch.no_grad():\n",
        "            output = model(images)\n",
        "\n",
        "        if isinstance(output, dict):\n",
        "            anomaly_maps = output[\"anomaly_map\"].cpu().numpy()\n",
        "            pred_scores  = output[\"pred_score\"].cpu().numpy()\n",
        "        else:\n",
        "            anomaly_maps = output.anomaly_map.cpu().numpy()\n",
        "            pred_scores  = output.pred_score.cpu().numpy()\n",
        "\n",
        "        pred_labels = (pred_scores >= threshold).astype(int)\n",
        "\n",
        "        for i in range(images.shape[0]):\n",
        "            gt = gt_labels[i].item()\n",
        "            pred = pred_labels[i]\n",
        "            score = pred_scores[i]\n",
        "\n",
        "            is_defective = (gt == 1)\n",
        "            is_false_positive = (gt == 0 and pred == 1)\n",
        "\n",
        "            # Only process if it's a defective item or a false positive\n",
        "            if not (is_defective or is_false_positive):\n",
        "                continue\n",
        "\n",
        "            # Image processing\n",
        "            img_tensor = images[i].cpu().permute(1, 2, 0).numpy()\n",
        "            img_tensor = (img_tensor - img_tensor.min()) / (img_tensor.max() - img_tensor.min() + 1e-8)\n",
        "            img_np = (img_tensor * 255).astype(np.uint8)\n",
        "\n",
        "            amap = anomaly_maps[i, 0]\n",
        "            fname = Path(str(image_paths[i])).stem\n",
        "\n",
        "            overlay = overlay_heatmap(img_np, amap)\n",
        "\n",
        "            # Plotting\n",
        "            fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
        "            axes[0].imshow(img_np, cmap=\"gray\"); axes[0].set_title(\"Input X-Ray\")\n",
        "            axes[1].imshow(amap, cmap=\"jet\");    axes[1].set_title(\"Raw Anomaly Map\")\n",
        "\n",
        "            gt_text = \"BAD\" if gt == 1 else \"GOOD\"\n",
        "            axes[2].imshow(overlay)\n",
        "            axes[2].set_title(f\"Overlay\\nScore: {score:.2f} | GT: {gt_text} | Threshold: {threshold:.4f}\")\n",
        "\n",
        "            for ax in axes: ax.axis(\"off\")\n",
        "            plt.tight_layout()\n",
        "\n",
        "            # Save to correct folder under SAVE_DIR\n",
        "            if is_false_positive:\n",
        "                plt.savefig(fp_dir / f\"FP_{fname}_score_{score:.2f}.png\", dpi=150, bbox_inches=\"tight\")\n",
        "                saved_fp += 1\n",
        "            elif is_defective:\n",
        "                plt.savefig(defective_dir / f\"DEFECT_{fname}_score_{score:.2f}.png\", dpi=150, bbox_inches=\"tight\")\n",
        "                saved_defective += 1\n",
        "\n",
        "            # Close figure immediately to free memory!\n",
        "            plt.close(fig)\n",
        "\n",
        "    print(f\"\\nPipeline Complete!\")\n",
        "    print(f\"Saved {saved_defective} Defective heatmaps to {defective_dir}/\")\n",
        "    print(f\"Saved {saved_fp} False Positive heatmaps to {fp_dir}/\")\n",
        "\n",
        "    # Compress the folders into standard zip files\n",
        "    print(\"\\n Zipping folders for easy download...\")\n",
        "    shutil.make_archive(str(base_dir / \"defective_heatmaps\"), 'zip', str(defective_dir))\n",
        "    shutil.make_archive(str(base_dir / \"false_positives\"), 'zip', str(fp_dir))\n",
        "    print(f\"Zipping complete! You can now download the .zip files from the {base_dir} folder.\")\n",
        "\n",
        "# Execute the visualization and zipping function\n",
        "save_and_zip_all_heatmaps(model=model, datamodule=datamodule, threshold=CHOSEN_THRESHOLD)"
      ]
