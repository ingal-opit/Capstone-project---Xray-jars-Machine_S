      "source": [
        "import time\n",
        "import torch\n",
        "\n",
        "print(\"Measuring Actual GPU Inference Latency (T4)...\")\n",
        "\n",
        "# 1. Ensure model is on the GPU\n",
        "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
        "model.to(device)\n",
        "model.eval()\n",
        "\n",
        "# 2. Create an exact replica of your 256x256 X-Ray image\n",
        "# (Because a CNN's speed is dictated purely by resolution, a dummy tensor\n",
        "# gives the exact same latency as a real image, but without dataloader bottlenecks).\n",
        "dummy_image = torch.randn(1, 3, 256, 256).to(device)\n",
        "\n",
        "# 3. GPU Warm-up Phase (CRITICAL)\n",
        "# The very first time a GPU runs a model, it has to compile \"CUDA Kernels\".\n",
        "# If we don't warm it up first, the timer will be artificially slow.\n",
        "with torch.no_grad():\n",
        "    for _ in range(15):\n",
        "        _ = model(dummy_image)\n",
        "\n",
        "# 4. The Speed Test\n",
        "num_tests = 100\n",
        "\n",
        "# Force Python to wait until the GPU is 100% ready before starting the stopwatch\n",
        "if device == \"cuda\":\n",
        "    torch.cuda.synchronize()\n",
        "\n",
        "start_time = time.time()\n",
        "\n",
        "with torch.no_grad():\n",
        "    for _ in range(num_tests):\n",
        "        _ = model(dummy_image)\n",
        "\n",
        "# Force Python to wait until the final image is fully processed before stopping the watch\n",
        "if device == \"cuda\":\n",
        "    torch.cuda.synchronize()\n",
        "\n",
        "end_time = time.time()\n",
        "\n",
        "# 5. Calculate and Print Results\n",
        "total_time_ms = (end_time - start_time) * 1000\n",
        "latency_per_image = total_time_ms / num_tests\n",
        "\n",
        "print(f\"Tested {num_tests} images on {device.upper()}.\")\n",
        "print(f\"Average Inference Time: {latency_per_image:.2f} ms per image\")\n",
        "\n",
        "# Business context\n",
        "jars_per_second = 1000 / latency_per_image\n",
        "print(f\"Max GPU Throughput: ~{jars_per_second:.0f} jars processed per second\")"
      ]
    }
