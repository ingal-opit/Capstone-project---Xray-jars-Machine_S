      "source": [
        "# ─── 2. SETUP DATA AND MODEL ───────────────────────────────────────────\n",
        "print(f\"Starting End-to-End Pipeline for {BACKBONE}...\\n\")\n",
        "\n",
        "datamodule = Folder(\n",
        "    name=DATASET_NAME,\n",
        "    root=DATASET_ROOT,\n",
        "    normal_dir=\"train/good\",\n",
        "    abnormal_dir=\"test/bad\",\n",
        "    normal_test_dir=\"test/good\",\n",
        "    train_batch_size=32,\n",
        "    eval_batch_size=32,\n",
        "    num_workers=0,\n",
        ")\n",
        "\n",
        "model = Patchcore(\n",
        "    backbone=BACKBONE,\n",
        "    layers=[\"layer2\", \"layer3\"],\n",
        "    num_neighbors=9,\n",
        "    pre_trained=True\n",
        ")\n",
        "# Disable progress bar to prevent Colab from freezing!\n",
        "engine = Engine(\n",
        "    accelerator=\"gpu\" if torch.cuda.is_available() else \"cpu\",\n",
        "    devices=1,\n",
        "    callbacks=[TQDMProgressBar(refresh_rate=0)]\n",
        ")"
      ]
