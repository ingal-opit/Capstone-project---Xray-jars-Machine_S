        "# ==========================================\n",
        "# EXTRACT PREDICTIONS & SUGGEST THRESHOLD\n",
        "# ==========================================\n",
        "print(\"Extracting Predictions...\")\n",
        "\n",
        "# Run predict to get the raw outputs from the test set\n",
        "predictions = engine.predict(model=model, datamodule=datamodule)\n",
        "\n",
        "y_true = []\n",
        "y_scores = []\n",
        "\n",
        "for batch in predictions:\n",
        "    labels = getattr(batch, 'label', None) or getattr(batch, 'gt_label', None)\n",
        "    scores = getattr(batch, 'pred_scores', None) or getattr(batch, 'pred_score', None)\n",
        "\n",
        "    if labels is not None and scores is not None:\n",
        "        y_true.extend(labels.cpu().numpy())\n",
        "        y_scores.extend(scores.cpu().numpy())\n",
        "\n",
        "y_true = np.array(y_true)\n",
        "y_scores = np.array(y_scores)\n",
        "\n",
        "# Calculate the optimal threshold automatically using F1 score\n",
        "precision, recall, thresholds = precision_recall_curve(y_true, y_scores)\n",
        "f1_scores = 2 * recall * precision / (recall + precision + 1e-10)\n",
        "suggested_threshold = thresholds[np.argmax(f1_scores)]\n",
        "\n",
        "print(f\"\\n SUGGESTION: The mathematically optimal threshold (highest F1-score) is: {suggested_threshold:.4f}\")\n",
        "print(\"You can use this value, or adjust it up/down depending on your factory's tolerance for False Positives.\")"
      ]
