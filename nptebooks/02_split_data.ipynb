      "source": [
        "\"\"\"\n",
        "restructure_data.py\n",
        "-------------------\n",
        "Converts raw Machine_S X-ray folders into the anomalib\n",
        "Folder datamodule layout required for PatchCore training.\n",
        "\n",
        "Output structure:\n",
        "    anomalib_data/\n",
        "        Machine_S/\n",
        "            train/\n",
        "                good/       (80% of GOOD images)\n",
        "            test/\n",
        "                good/       (20% of GOOD images)\n",
        "                bad/        (100% of BAD images)\n",
        "\n",
        "After restructuring, a verification step confirms that no training image\n",
        "appears in the test split.\n",
        "\"\"\"\n",
        "\n",
        "from __future__ import annotations\n",
        "\n",
        "import random\n",
        "import shutil\n",
        "from pathlib import Path\n",
        "from typing import Optional\n",
        "\n",
        "# --- Configuration ---\n",
        "\n",
        "# Input: raw data root\n",
        "\n",
        "RAW_ROOT       = Path(\"Machine_S": PROJECT_ROOT / "data" / "raw_data" / "Machine_S",")\n",
        "MACHINE_S_SRC  = RAW_ROOT / \"raw_data/Machine_S\"\n",
        "OUTPUT_ROOT    = Path(\"/content/anomalib_data\")\n",
        "MACHINE_S_OUT  = OUTPUT_ROOT / \"Machine_S\"\n",
        "\n",
        "# Split ratio: fraction of GOOD images assigned to train/good\n",
        "TRAIN_RATIO = 0.80\n",
        "\n",
        "# Fixed seed for reproducible splits\n",
        "SEED = 42\n",
        "\n",
        "# Supported image extensions\n",
        "IMG_EXTS = {\".png\", \".jpg\", \".jpeg\", \".tif\", \".tiff\", \".bmp\"}\n",
        "\n",
        "# All output images are written as PNG\n",
        "OUTPUT_FORMAT = \".png\"\n",
        "\n",
        "\n",
        "# ---------------------------------------------------------------------------\n",
        "# General helpers\n",
        "# ---------------------------------------------------------------------------\n",
        "\n",
        "def collect_images(folder: Path) -> list[Path]:\n",
        "    \"\"\"Return sorted image paths in a directory (non-recursive).\"\"\"\n",
        "    return sorted(p for p in folder.iterdir() if p.suffix.lower() in IMG_EXTS)\n",
        "\n",
        "\n",
        "def make_dirs(machine_root: Path) -> dict[str, Path]:\n",
        "    \"\"\"Create the anomalib Folder layout and return a path dictionary.\"\"\"\n",
        "    dirs = {\n",
        "        \"train_good\": machine_root / \"train\" / \"good\",\n",
        "        \"test_good\":  machine_root / \"test\"  / \"good\",\n",
        "        \"test_bad\":   machine_root / \"test\"  / \"bad\",\n",
        "    }\n",
        "    for d in dirs.values():\n",
        "        d.mkdir(parents=True, exist_ok=True)\n",
        "    return dirs\n",
        "\n",
        "\n",
        "def copy_image(\n",
        "    src: Path, dst_dir: Path, stem_override: Optional[str] = None\n",
        ") -> Path:\n",
        "    \"\"\"Copy src to dst_dir with an optional filename override. Returns the destination path.\"\"\"\n",
        "    stem = stem_override if stem_override else src.stem\n",
        "    dst = dst_dir / (stem + OUTPUT_FORMAT)\n",
        "    shutil.copy2(src, dst)\n",
        "    return dst\n",
        "\n",
        "\n",
        "def split_paths(\n",
        "    paths: list[Path], train_ratio: float = TRAIN_RATIO, seed: int = SEED\n",
        ") -> tuple[list[Path], list[Path]]:\n",
        "    \"\"\"Shuffle and split paths into (train, test) lists.\"\"\"\n",
        "    shuffled = list(paths)\n",
        "    random.Random(seed).shuffle(shuffled)\n",
        "    n_train = max(1, int(len(shuffled) * train_ratio))\n",
        "    return shuffled[:n_train], shuffled[n_train:]\n",
        "\n",
        "\n",
        "# ---------------------------------------------------------------------------\n",
        "# Restructure — Machine_S (simple copy + split)\n",
        "# ---------------------------------------------------------------------------\n",
        "\n",
        "def restructure_machine_s() -> None:\n",
        "    print(\"\\n\" + \"=\" * 60)\n",
        "    print(\"  Restructuring Machine_S (single view)\")\n",
        "    print(\"=\" * 60)\n",
        "\n",
        "    good_src = MACHINE_S_SRC / \"GOOD\"\n",
        "    bad_src  = MACHINE_S_SRC / \"BAD\"\n",
        "\n",
        "    if not good_src.exists():\n",
        "        print(f\"  GOOD folder not found: {good_src}\")\n",
        "        return\n",
        "    if not bad_src.exists():\n",
        "        print(f\"  BAD folder not found: {bad_src}\")\n",
        "        return\n",
        "\n",
        "    dirs = make_dirs(MACHINE_S_OUT)\n",
        "\n",
        "    # GOOD: split 80 / 20\n",
        "    all_good = collect_images(good_src)\n",
        "    train_good, test_good = split_paths(all_good)\n",
        "\n",
        "    print(f\"\\n  GOOD images : {len(all_good)}\")\n",
        "    print(f\"    -> train/good : {len(train_good)}\")\n",
        "    print(f\"    -> test/good  : {len(test_good)}\")\n",
        "\n",
        "    for p in train_good:\n",
        "        copy_image(p, dirs[\"train_good\"])\n",
        "    for p in test_good:\n",
        "        copy_image(p, dirs[\"test_good\"])\n",
        "\n",
        "    # BAD: all images go to test/bad\n",
        "    all_bad = collect_images(bad_src)\n",
        "    print(f\"\\n  BAD images  : {len(all_bad)}\")\n",
        "    print(f\"    -> test/bad : {len(all_bad)}\")\n",
        "\n",
        "    for p in all_bad:\n",
        "        copy_image(p, dirs[\"test_bad\"])\n",
        "\n",
        "    print(f\"\\n  Machine_S restructured -> {MACHINE_S_OUT}\")\n",
        "    _print_layout(MACHINE_S_OUT)\n",
        "\n",
        "\n",
        "# ---------------------------------------------------------------------------\n",
        "# Verification\n",
        "# ---------------------------------------------------------------------------\n",
        "\n",
        "def _print_layout(root: Path) -> None:\n",
        "    \"\"\"Print a file-count summary of the output directory tree.\"\"\"\n",
        "    print(f\"\\n  Output layout ({root.name}):\")\n",
        "    for split in [\"train\", \"test\"]:\n",
        "        split_dir = root / split\n",
        "        if not split_dir.exists():\n",
        "            continue\n",
        "        for sub in sorted(split_dir.iterdir()):\n",
        "            if sub.is_dir():\n",
        "                n = len([p for p in sub.iterdir() if p.suffix.lower() in IMG_EXTS])\n",
        "                print(f\"    {split}/{sub.name}/  ->  {n} images\")\n",
        "\n",
        "\n",
        "def verify_outputs() -> None:\n",
        "    \"\"\"Quick sanity check: confirm no train images appear in the test split.\"\"\"\n",
        "    print(\"\\n\" + \"=\" * 60)\n",
        "    print(\"  Verification\")\n",
        "    print(\"=\" * 60)\n",
        "\n",
        "    train_good = set(\n",
        "        p.stem\n",
        "        for p in (MACHINE_S_OUT / \"train\" / \"good\").glob(\"*\")\n",
        "        if p.suffix.lower() in IMG_EXTS\n",
        "    )\n",
        "    test_good = set(\n",
        "        p.stem\n",
        "        for p in (MACHINE_S_OUT / \"test\" / \"good\").glob(\"*\")\n",
        "        if p.suffix.lower() in IMG_EXTS\n",
        "    )\n",
        "    test_bad = set(\n",
        "        p.stem\n",
        "        for p in (MACHINE_S_OUT / \"test\" / \"bad\").glob(\"*\")\n",
        "        if p.suffix.lower() in IMG_EXTS\n",
        "    )\n",
        "\n",
        "    overlap = train_good & test_good\n",
        "    status = \"OK\" if not overlap else f\"ERROR: {len(overlap)} duplicates!\"\n",
        "    print(f\"\\n  [Machine_S]\")\n",
        "    print(f\"    train/good intersect test/good : {status}\")\n",
        "\n",
        "    if not train_good and not test_good and not test_bad:\n",
        "        print(f\"    Warning: No output found at {MACHINE_S_OUT} — did restructuring run?\")\n",
        "\n",
        "    print()\n",
        "\n",
        "\n",
        "# ---------------------------------------------------------------------------\n",
        "# Main\n",
        "# ---------------------------------------------------------------------------\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    Path(\"results\").mkdir(exist_ok=True)\n",
        "\n",
        "    restructure_machine_s()\n",
        "    verify_outputs()\n",
        "\n",
        "    print(\"=\" * 60)\n",
        "    print(\"  Dataset restructuring complete.\")\n",
        "    print(f\"  Root: {OUTPUT_ROOT.resolve()}\")\n",
        "    print(\"=\" * 60)"
      ]
    },
